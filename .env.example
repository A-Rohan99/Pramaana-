# URL safety agent -- required for real threat-intel checks. Without
# these, the URL agent falls back to structural checks only and will
# honestly report "unknown" rather than a false all-clear.
GOOGLE_SAFE_BROWSING_API_KEY=your_google_safe_browsing_api_key
VIRUSTOTAL_API_KEY=your_virustotal_api_key
# Required for dynamic online government scheme lookup AND LLM pipeline fallback.
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
# Optional: Telegram bot for real-world message ingestion.
# Create a bot via @BotFather on Telegram, copy the token here.
# If left blank the Telegram channel is simply disabled; the web UI still works.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
